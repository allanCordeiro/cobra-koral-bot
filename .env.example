# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
USER_ID=your_telegram_user_id_here

# Storage Configuration
# STORAGE_TYPE: Choose "file" for local file storage or "gcs" for Google Cloud Storage
# Defaults to "file" if not specified
STORAGE_TYPE=file

# File Storage Configuration (when STORAGE_TYPE=file)
# State File Path (optional, defaults to ./data/state.json)
# For local development, use relative path: ./data/state.json
# For Docker/Cloud Run with mounted volume, use: /app/data/state.json
# STATE_FILE_PATH=./data/state.json

# Google Cloud Storage Configuration (when STORAGE_TYPE=gcs)
# GCS_BUCKET: The name of your Google Cloud Storage bucket (REQUIRED for GCS)
# GCS_STATE_FILE: The object name in the bucket (defaults to state.json)
# GCS_BUCKET=weather-worker-state-your-project-id
# GCS_STATE_FILE=state.json
